### **Rate Limiting**
```javascript
// Rate limiting configuration
const limiter = rateLimit({
  windowMs: 15 * 60 * 1000, // 15 minutes
  max: process.env.NODE_ENV === 'development' ? 1000 : 100,
  message: 'Too many requests from this IP',
  standardHeaders: true,
  legacyHeaders: false
});

// Apply to API routes, exclude OAuth
app.use('/api/', (req, res, next) => {
  if (req.path.startsWith('/auth/google') || req.path.startsWith('/auth/linkedin')) {
    return next();
  }
  return limiter(req, res, next);
});
```

### **CORS Security**
```javascript
// CORS configuration for mobile and web
const corsOptions = {
  origin: function (origin, callback) {
    const allowedOrigins = [
      'http://localhost:3000',
      'https://your-frontend-domain.com',
      'capacitor://localhost',
      'ionic://localhost'
    ];
    
    if (!origin || allowedOrigins.includes(origin)) {
      callback(null, true);
    } else {
      callback(new Error('Not allowed by CORS'));
    }
  },
  credentials: true,
  methods: ['GET', 'POST', 'PUT', 'DELETE', 'PATCH', 'OPTIONS'],
  allowedHeaders: ['Content-Type', 'Authorization', 'X-Requested-With']
};
```

### **XSS Protection**
```javascript
// Custom XSS sanitization for resume content
const sanitizeObject = (obj, isResumeRequest = false) => {
  if (typeof obj === 'string') {
    if (isResumeRequest && isResumeContentField(obj)) {
      // Permissive XSS filter for CKEditor content
      return xss(obj, {
        whiteList: {
          'p': ['style'], 'span': ['style'], 'strong': [], 'b': [],
          'em': [], 'i': [], 'u': [], 'ol': ['class', 'style'],
          'ul': ['class', 'style'], 'li': ['class', 'data-list-item-id', 'style']
        },
        stripIgnoreTag: true,
        stripIgnoreTagBody: ['script']
      });
    } else {
      // Standard XSS sanitization
      return xss(obj);
    }
  }
  // Recursive sanitization for nested objects
};
```

