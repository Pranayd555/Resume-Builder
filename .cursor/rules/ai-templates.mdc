### **AI Usage Patterns**
```javascript
// AI action tracking
const trackAIAction = async (userId, actionType, tokensUsed) => {
  const usage = {
    userId,
    actionType, // 'parse-resume', 'analyze-resume', 'generate-content'
    tokensUsed,
    timestamp: new Date()
  };
  
  // Log usage for analytics
  await AIUsage.create(usage);
  
  // Update token balance
  await trackTokenUsage(userId, actionType, tokensUsed);
};

// AI action limits
const checkAIActionLimit = async (req, res, next) => {
  const tokenData = await calculateTotalTokens(req.user.id);
  
  if (tokenData.totalTokenBalance <= 0) {
    return res.status(402).json({
      success: false,
      error: 'Insufficient tokens for AI action',
      data: { tokenBalance: tokenData.totalTokenBalance }
    });
  }
  
  next();
};
```

