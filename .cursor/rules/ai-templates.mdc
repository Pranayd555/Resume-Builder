### **Document Processing Pipeline**
```javascript
// Document parsing workflow
const parseDocument = async (buffer, mimetype, filename) => {
  // 1. Validate file type
  if (!isValidDocumentType(mimetype)) {
    throw new Error('Unsupported file type');
  }
  
  // 2. Extract text based on type
  let extractedText = '';
  if (mimetype === 'application/pdf') {
    extractedText = await parsePDF(buffer);
  } else if (mimetype.includes('wordprocessingml')) {
    extractedText = await parseWord(buffer);
  }
  
  // 3. AI parsing
  const parsedData = await parseResumeText(extractedText);
  
  return {
    originalText: extractedText,
    parsedData: parsedData,
    confidence: parsedData.confidence || 0.8
  };
};
```

### **Token Management System**
```javascript
// Token calculation and usage tracking
const calculateTotalTokens = async (userId) => {
  const user = await User.findById(userId);
  const subscription = await Subscription.findOne({ user: userId });
  
  const purchasedTokens = user.tokens || 0;
  const freeTokens = subscription.freeTokens || 0;
  const freeTokensUsed = subscription.freeTokensUsed || 0;
  const remainingFreeTokens = Math.max(0, freeTokens - freeTokensUsed);
  
  return {
    totalTokenBalance: purchasedTokens + remainingFreeTokens,
    purchasedTokens,
    remainingFreeTokens,
    freeTokens,
    freeTokensUsed,
    subscription
  };
};

// Token usage tracking
const trackTokenUsage = async (userId, usageType, tokensUsed) => {
  const subscription = await Subscription.findOne({ user: userId });
  
  if (subscription.freeTokens > subscription.freeTokensUsed) {
    subscription.freeTokensUsed += tokensUsed;
  } else {
    // Deduct from purchased tokens
    const user = await User.findById(userId);
    user.tokens = Math.max(0, user.tokens - tokensUsed);
    await user.save();
  }
  
  await subscription.save();
};
```

