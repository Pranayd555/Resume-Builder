### **Token Management**
```javascript
// Token calculation and usage tracking
const calculateTotalTokens = async (userId) => {
  const user = await User.findById(userId);
  const subscription = await Subscription.findOne({ user: userId });
  
  return {
    totalTokenBalance: user.tokens + subscription.freeTokens,
    purchasedTokens: user.tokens,
    remainingFreeTokens: subscription.remainingFreeTokens
  };
};
```

### **Security Headers**
```javascript
// Security middleware configuration
app.use(helmet({
  crossOriginResourcePolicy: { policy: "cross-origin" },
  contentSecurityPolicy: {
    directives: {
      defaultSrc: ["'self'"],
      styleSrc: ["'self'", "'unsafe-inline'", "https:"],
      scriptSrc: ["'self'", "https:"],
      imgSrc: ["'self'", "data:", "https:"]
    }
  }
}));
```

### **CORS Configuration**
```javascript
// CORS for mobile and web clients
const corsOptions = {
  origin: function (origin, callback) {
    const allowedOrigins = [
      'http://localhost:3000',
      'capacitor://localhost',
      'ionic://localhost'
    ];
    
    if (!origin || allowedOrigins.includes(origin)) {
      callback(null, true);
    } else {
      callback(new Error('Not allowed by CORS'));
    }
  },
  credentials: true
};
```

