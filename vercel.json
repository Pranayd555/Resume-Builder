{
  "version": 2,
  "name": "resume-builder",
  "framework": "create-react-app",
  "buildCommand": "cd resume-builder && npm ci && npm run build",
  "outputDirectory": "resume-builder/build",
  "installCommand": "cd resume-builder && npm ci",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://resume-builder-m5ef.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/app/(.*)",
      "destination": "/$1",
      "permanent": false
    }
  ],
  "env": {
    "CI": "false",
    "GENERATE_SOURCEMAP": "false",
    "REACT_APP_VERSION": "$VERCEL_GIT_COMMIT_SHA"
  },
  "build": {
    "env": {
      "CI": "false",
      "GENERATE_SOURCEMAP": "false"
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "dev": true,
      "develop": true
    }
  },
  "github": {
    "enabled": true,
    "autoAlias": true
  }
}