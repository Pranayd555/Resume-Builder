# Render-optimized npm configuration
prefer-offline=true
no-audit=true
no-optional=true
cache-min=3600
fetch-retries=3
fetch-retry-mintimeout=5000
fetch-retry-maxtimeout=60000
maxsockets=1
timeout=300000
progress=false
production=true

# Render-specific optimizations
cache=/opt/render/.npm
registry=https://registry.npmjs.org/ 