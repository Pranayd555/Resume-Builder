# =============================================================================
# ENVIRONMENT TEMPLATE - Resume Builder Backend
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control!

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development
PORT=5000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Development: Use your development database
# Production/Staging: Use separate databases with different credentials
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority&appName=ResumeBuilder

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Generate strong secrets using: node -p "require('crypto').randomBytes(64).toString('hex')"
# Use different secrets for each environment!
JWT_SECRET=your-super-strong-jwt-secret-at-least-64-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-strong-refresh-secret-at-least-64-characters-long

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
# Generate a strong secret using: node -p "require('crypto').randomBytes(64).toString('hex')"
SESSION_SECRET=your-super-strong-session-secret-at-least-64-characters-long

# =============================================================================
# OAUTH CONFIGURATION
# =============================================================================
# Create separate OAuth applications for production and staging
# Google OAuth - Get from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# LinkedIn OAuth - Get from: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# =============================================================================
# RAZORPAY CONFIGURATION
# =============================================================================
# Get your keys from: https://dashboard.razorpay.com/app/keys
# Use test keys for development, live keys for production
RAZORPAY_KEY_ID=rzp_test_your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Webhook secret for signature verification (get from Razorpay dashboard)
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret


# =============================================================================
# AI CONFIGURATION
# =============================================================================
# Google Gemini AI API Key - Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# ENCRYPTION_KEY - generate from scripts/generate-key
# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# For Gmail: Use App Passwords (not your regular password)
# Get App Password: Google Account > Security > App passwords
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password
EMAIL_FROM_NAME=Presmistique - AI Resume Builder
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Alternative email services:
# For Outlook.com/Hotmail:
# EMAIL_SERVICE=outlook
# EMAIL_HOST=smtp-mail.outlook.com

# For Outlook 365:
# EMAIL_SERVICE=outlook365
# EMAIL_HOST=smtp.office365.com

# For custom SMTP:
# EMAIL_SERVICE=smtp
# EMAIL_HOST=your-smtp-host.com
# EMAIL_PORT=587
# EMAIL_SECURE=false

# =============================================================================
# SUPPORT CONFIGURATION
# =============================================================================
ADMIN_EMAIL=admin@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com
APP_NAME=Presmistique - AI Resume Builder

# =============================================================================
# FILE UPLOAD CONFIGURATION (Optional)
# =============================================================================
# Cloudinary for image storage
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# =============================================================================
# CLIENT CONFIGURATION
# =============================================================================
# Frontend URLs - Update these for each environment
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
MOBILE_APP_URL_SCHEME=resumebuilder

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# =============================================================================
# ENVIRONMENT EXAMPLES
# =============================================================================

# DEVELOPMENT ENVIRONMENT:
# NODE_ENV=development
# PORT=5000
# CLIENT_URL=http://localhost:3000
# CORS_ORIGIN=http://localhost:3000
# LOG_LEVEL=debug

# STAGING ENVIRONMENT:
# NODE_ENV=staging
# PORT=10000
# CLIENT_URL=https://your-staging-frontend.vercel.app
# CORS_ORIGIN=https://your-staging-frontend.vercel.app
# LOG_LEVEL=info

# PRODUCTION ENVIRONMENT:
# NODE_ENV=production
# PORT=10000
# CLIENT_URL=https://your-production-frontend.vercel.app
# CORS_ORIGIN=https://your-production-frontend.vercel.app
# LOG_LEVEL=error
# BCRYPT_SALT_ROUNDS=14
# RATE_LIMIT_MAX_REQUESTS=50
