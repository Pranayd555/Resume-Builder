{
  "name": "resume-builder-backend",
  "version": "1.0.0",
  "description": "Backend API for Resume Builder - Mobile and Web Ready",
  "main": "server.js",
  "scripts": {
    "build": "node scripts/build.js",
    "build:fast": "npm install --only=production --no-audit --progress=false",
    "build:win": "build.bat",
    "start": "node scripts/start.js",
    "start:win": "start.bat",
    "dev": "nodemon server.js",
    "test": "echo 'No tests configured - API endpoints tested via integration tests'",
    "seed:all-templates": "node scripts/seedAllTemplates.js",
    "test:templates": "node scripts/testTemplates.js",
    "generate-thumbnails": "node scripts/generatePuppeteerThumbnails.js",
    "update-thumbnails": "node scripts/updateTemplatesWithPuppeteerThumbnails.js",
    "seed": "node scripts/seedDatabase.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mongoose": "^7.6.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.6",
    "officegen": "^0.6.5",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-linkedin-oauth2": "^2.0.0",
    "puppeteer": "^21.5.2",
    "sharp": "^0.34.3",
    "stripe": "^13.6.0",
    "winston": "^3.11.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "npmConfig": {
    "prefer-offline": true,
    "no-audit": true,
    "no-optional": true
  },
  "keywords": [
    "resume",
    "builder",
    "api",
    "nodejs",
    "express",
    "mongodb",
    "mobile",
    "web"
  ],
  "author": "Resume Builder Team",
  "license": "MIT"
}
