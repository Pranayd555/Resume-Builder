{
  "name": "resume-builder-backend",
  "version": "1.0.0",
  "description": "Backend API for Resume Builder - Mobile and Web Ready",
  "main": "server.js",
  "scripts": {
    "build": "node scripts/build.js",
    "build:render": "node scripts/local-build-for-render.js",
    "render:build": "node scripts/render-build.js",
    "test:build": "node scripts/test-build.js",
    "start": "node scripts/start.js",
    "dev": "nodemon server.js",
    "test": "echo 'No tests configured - API endpoints tested via integration tests'",
    "seed:all-templates": "node scripts/seedAllTemplates.js",
    "test:templates": "node scripts/testTemplates.js",
    "test:styling": "node scripts/testTemplateStyling.js",
    "generate-thumbnails": "node scripts/generatePuppeteerThumbnails.js",
    "update-thumbnails": "node scripts/updateTemplatesWithPuppeteerThumbnails.js",
    "seed": "node scripts/seedDatabase.js",
    "unlock-account": "node scripts/unlock-account.js",
    "add-tokens": "node scripts/add-tokens.js",
    "add-tokens-force": "node scripts/add-tokens.js"
  },
  "dependencies": {
    "@google/genai": "^1.16.0",
    "@sparticuz/chromium": "^119.0.0",
    "archiver": "^6.0.1",
    "bcryptjs": "^2.4.3",
    "chrono-node": "^2.8.4",
    "compression": "^1.7.4",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.10.0",
    "express-session": "^1.18.2",
    "express-validator": "^7.0.1",
    "fuse.js": "^7.1.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.10.0",
    "moment": "^2.30.1",
    "mongoose": "^7.6.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.6",
    "officegen": "^0.6.5",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-openidconnect": "^0.1.2",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^21.5.2",
    "razorpay": "^2.9.6",
    "sharp": "^0.34.3",
    "winston": "^3.11.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": "22.17.0",
    "npm": ">=8.0.0"
  },
  "npmConfig": {
    "prefer-offline": true,
    "no-audit": true,
    "no-optional": false
  },
  "keywords": [
    "resume",
    "builder",
    "api",
    "nodejs",
    "express",
    "mongodb",
    "mobile",
    "web"
  ],
  "author": "Resume Builder Team",
  "license": "MIT"
}
