# =============================================================================
# FRONTEND ENVIRONMENT TEMPLATE - Resume Builder
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control!

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Backend API URL - Update for each environment
REACT_APP_API_URL=http://localhost:5000/api
# Production example:
# REACT_APP_API_URL=https://api.yourdomain.com/api

# =============================================================================
# OPTIONAL - Third-party integrations
# =============================================================================
# CKEditor license (optional - get from https://ckeditor.com/)
# REACT_APP_CKEDITOR_LICENSE_KEY=your-ckeditor-license-key

# Razorpay Key ID (optional - public key for payment UI, get from https://dashboard.razorpay.com/)
# REACT_APP_RAZORPAY_KEY_ID=rzp_test_your-key-id
